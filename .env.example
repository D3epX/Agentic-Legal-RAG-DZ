# ============================================================
# Legal Chatbot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# ============================================================

# ---- Database ----
POSTGRES_DB=legal_chatbot
POSTGRES_USER=legal_admin
POSTGRES_PASSWORD=changeme_secure_password_here
REDIS_PASSWORD=changeme_redis_password_here

# ---- Groq API (LLM - Chat generation) ----
GROQ_API_KEY=gsk_your_actual_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Groq API (LLM - Internal: classifier, rewriter, faithfulness) ----
GROQ_INTERNAL_API_KEY=gsk_your_internal_groq_api_key_here
GROQ_INTERNAL_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=2048

# ---- Gemini API (LLM - Chat generation) ----
GENAI_API_KEY=your-gemini-api-key-here
GENAI_MODEL=gemini-2.0-flash

# ---- Gemini API (LLM - Internal logic) ----
GENAI_INTERNAL_API_KEY=your-gemini-internal-api-key-here
GENAI_INTERNAL_MODEL=gemini-2.0-flash

# ---- LLM Provider Selection (gemini | groq) ----
LLM_PROVIDER_CHAT=gemini
LLM_PROVIDER_INTERNAL=gemini

# ---- Embeddings ----
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# ---- Qdrant (vector store) ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ---- Redis / Celery ----
REDIS_URL=redis://:redis123@redis:6379/0
CELERY_BROKER_URL=redis://:redis123@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis123@redis:6379/2

# ---- FastAPI App ----
ENVIRONMENT=production
API_HOST=0.0.0.0
API_PORT=8000

# ---- Vector Search ----
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.35

# ---- Document Processing ----
MAX_UPLOAD_SIZE_MB=20
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_CHUNKS_PER_DOC=500

# ---- Chat Memory ----
MAX_HISTORY_MESSAGES=20
HISTORY_SUMMARY_THRESHOLD=12
TOKEN_BUDGET_HISTORY=1500
TOKEN_BUDGET_SUMMARY=500

# ---- Web Search (Exa - RAG fallback) ----
EXA_API_KEY=your-exa-api-key-here
EXA_ENABLED=false

# ---- Web Search (Tavily - user-triggered) ----
TAVILY_API_KEY=your-tavily-api-key-here
TAVILY_ENABLED=false
